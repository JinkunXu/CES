# scripts/run_kabb_flask.py
import sys, os, json, argparse, asyncio, yaml
from typing import Optional, Dict, Any
from tqdm import tqdm

# Make repo importable
script_dir = os.path.dirname(os.path.abspath(__file__))
project_root = os.path.dirname(script_dir)
if project_root not in sys.path:
    sys.path.insert(0, project_root)

import scripts.run_kabb as rk
from kabb.llm_client import LLMClient
from kabb.utils import logic_based_domain_inference
from scripts.run_kabb import (
    get_domain_all_expert_responses,
    get_integrated_content_new,
    integrate_expert_responses,
)
from scripts.src.dataset_loader import iter_dataset


def load_config(path: str) -> dict:
    with open(path, "r", encoding="utf-8") as f:
        return yaml.safe_load(f)


def extract_question_id(raw: Dict[str, Any], fallback: int) -> Any:
    for k in ["idx", "question_id", "id", "qid"]:
        if k in raw:
            return raw[k]
    return fallback


async def run_one(cfg: dict, llm_client: LLMClient, user_input: str) -> Dict[str, Any]:
    """
    对齐 run_kabb_alpacaeval 的调用风格 + 保留中间产物用于 log。
    """
    domain_settings = cfg.get("domain_inference_settings", {})
    knowledge_graph = cfg.get("knowledge_graph", {})
    experts_config = cfg.get("experts", {})
    integrator_config = cfg.get("integrator", {})
    system_prompt = cfg["system_prompts"]["default"]

    # 1) domain inference
    domain_label, cleaned_input = logic_based_domain_inference(user_input, domain_settings, top_k=1)

    DEFAULT_DOMAIN = list(experts_config.keys())[0] if experts_config else "stem"
    if isinstance(domain_label, list):
        missing = [d for d in domain_label if d not in experts_config]
        if missing:
            domain_label = DEFAULT_DOMAIN
    else:
        if domain_label not in experts_config:
            domain_label = DEFAULT_DOMAIN

    # normalize domain_label to list
    if not isinstance(domain_label, list):
        domain_label = [domain_label]

    # 2) collect selected experts (对齐你原逻辑：domain -> experts_config[domain])
    selected_experts = []
    for d in domain_label:
        selected_experts.extend(experts_config.get(d, []))

    # 3) get expert responses (对齐 alpacaeval 的函数签名)
    all_responses = {}
    for d in domain_label:
        exps = [e for e in selected_experts if d in (e.get("domain_expertise", []) or [])] or selected_experts
        all_responses[d] = await get_domain_all_expert_responses(
            d, exps, system_prompt, llm_client, cleaned_input
        )

    # 4) integrate (对齐 alpacaeval 的签名)
    integrated_content = get_integrated_content_new(all_responses, selected_experts, use_contextual_expert=False)

    integrator_info = integrator_config.get("default")
    final_answer = await integrate_expert_responses(
        integrator_info, system_prompt, llm_client, cleaned_input, integrated_content
    )

    final_text = final_answer["text"] if isinstance(final_answer, dict) else str(final_answer)
    final_text = (final_text or "").strip()

    return {
        "domain_label": domain_label,
        "cleaned_input": cleaned_input,
        "domain_expert_responses": all_responses,
        "integrated_content": integrated_content,
        "final": final_answer,
        "final_text": final_text,
        "question_cost_usd": float(getattr(rk, "TOTAL_COST", 0.0)),
        "question_calls": int(getattr(rk, "TOTAL_CALLS", 0)),
    }


async def main_async():
    ap = argparse.ArgumentParser()

    # ---- KABB config ----
    ap.add_argument("--config", type=str, required=True)
    ap.add_argument("--provider", type=str, default=None)  # 若不传，走 config/env
    ap.add_argument("--limit", type=int, default=None)
    ap.add_argument("--seed", type=int, default=0)

    # ---- dataset loader args ----
    ap.add_argument("--dataset", type=str, default="flask_hard",
                    choices=["alpacaeval2", "mtbench", "flask_hard", "generic"])
    ap.add_argument("--dataset_hf_path", type=str, default=None)
    ap.add_argument("--dataset_config", type=str, default=None)
    ap.add_argument("--dataset_split", type=str, default=None)
    ap.add_argument("--dataset_text_fields", type=str, default="instruction")

    # ---- outputs ----
    ap.add_argument("--out_answers", type=str, required=True)
    ap.add_argument("--out_log", type=str, required=True)

    args = ap.parse_args()
    if args.limit is not None and args.limit < 0:
        args.limit = None

    os.makedirs(os.path.dirname(args.out_answers) or ".", exist_ok=True)
    os.makedirs(os.path.dirname(args.out_log) or ".", exist_ok=True)

    cfg = load_config(args.config)

    llm_cfg = cfg.get("llm_api", {})
    provider = args.provider or os.environ.get("LLM_PROVIDER") or llm_cfg.get("provider") or "openrouter"
    api_key = os.environ.get("OPENROUTER_API_KEY") or llm_cfg.get("api_key") or "<YOUR_KEY_HERE>"
    llm_client = LLMClient(api_key=api_key, provider=provider)

    it = iter_dataset(
        dataset=args.dataset,
        limit=args.limit,
        seed=args.seed,
        dataset_hf_path=args.dataset_hf_path,
        dataset_config=args.dataset_config,
        dataset_split=args.dataset_split,
        dataset_text_fields=args.dataset_text_fields,
    )

    with open(args.out_answers, "w", encoding="utf-8") as wf_ans, \
         open(args.out_log, "w", encoding="utf-8") as wf_log:

        for t, (prompt, raw) in enumerate(tqdm(it, total=args.limit if args.limit else None)):
            qid = extract_question_id(raw, fallback=t)

            rk.reset_question_cost()
            rec = await run_one(cfg=cfg, llm_client=llm_client, user_input=prompt)

            # FLASK eval required
            wf_ans.write(json.dumps({"question_id": qid, "text": rec["final_text"]}, ensure_ascii=False) + "\n")
            wf_ans.flush()

            wf_log.write(json.dumps({
                "t": t,
                "dataset": args.dataset,
                "question_id": qid,
                "prompt": prompt,
                **rec,
                "raw": raw,
            }, ensure_ascii=False) + "\n")
            wf_log.flush()


def main():
    asyncio.run(main_async())


if __name__ == "__main__":
    main()
